NODE_ENV=development
PORT=4001
MONGODB_URI=mongodb://127.0.0.1:27017/practicedevelopment
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_ORIGIN=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174,https://infra-as-a-code.vercel.app
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Optional for local development. In production, prefer an ECS/EKS/EC2/host role.
# This identity must be allowed to call sts:AssumeRole into connected customer AWS accounts.
AWS_ACCESS_KEY_ID=your-base-access-key
AWS_SECRET_ACCESS_KEY=your-base-secret-key
AWS_SESSION_TOKEN=
AWS_REGION=ap-south-1

# Real deployment runner. Set true only when you are ready for Terraform to create AWS resources.
TERRAFORM_APPLY_ENABLED=true
TERRAFORM_BIN=terraform
TERRAFORM_WORK_DIR=

# FastAPI RAG service created from wellarchitected-framework.pdf
RAG_API_URL=http://127.0.0.1:8000

# GitHub OAuth app for Vercel-style repository connection.
# Callback URL example: http://localhost:4001/api/v1/github/oauth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=
GITHUB_TOKEN_ENCRYPTION_KEY=
