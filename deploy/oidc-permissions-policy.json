{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DeployToS3",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::infraflow-static-20260721103059975700000001",
        "arn:aws:s3:::infraflow-static-20260721103059975700000001/*"
      ]
    },
    {
      "Sid": "InvalidateCloudFront",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation"
      ],
      "Resource": "*"
    }
  ]
}